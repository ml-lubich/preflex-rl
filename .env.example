# Copy to .env and fill in. Never commit .env (it is gitignored).

# MiniMax (OpenAI-compatible): https://platform.minimax.io/docs/api-reference/text-openai-api
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2
# Docs recommend 1.0; must be in (0.0, 1.0]
MINIMAX_TEMPERATURE=1.0

# Optional: run scripts/crew_debrief.py with CrewAI instead / after MiniMax logic
# PREFLEX_USE_CREW=0
